# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# Editor
.vscode/

# local env files
.env*.local

# generated env module (produced by metro.config.js at startup)
lib/env.generated.ts

# typescript
*.tsbuildinfo

# generated native folders (tracked for bare workflow)
/ios

# Supabase local temp files
supabase/.temp/

# Android debug keystore (regenerated automatically)
android/app/debug.keystore

# Keystores — never commit (debug is auto-generated, release is secret)
*.keystore

# Firebase config — contains project IDs, keep out of public repos
google-services.json

# Play Store service account key — never commit
play-store-key.json

# Local keystore credentials — never commit
android/keystore.properties
